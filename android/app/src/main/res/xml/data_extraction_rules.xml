<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup / transfer rules for Android 12 (API 31) and above.
  Cloud backup excludes the rotating JSON auto-backups under the app documents
  directory (data root/app_flutter/backups) — they duplicate the SQLite
  database, double the cleartext copies in Google Drive, and count against the
  ~25 MB Auto Backup quota (#36); the database alone restores everything.
  Device-to-device transfer has no quota, so it keeps the default (everything,
  including the local backup rotation).
  Both channels exclude app_flutter/.install_id (#62): the install fingerprint
  file must NOT follow the database to another device — the mismatch between
  the copied database's fingerprint and the missing/different file is how the
  app detects an OS-level restore and drops the old device's Google Drive
  sync identity (see lib/data/install_id.dart).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="app_flutter/backups"/>
        <exclude domain="root" path="app_flutter/.install_id"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="app_flutter/.install_id"/>
    </device-transfer>
</data-extraction-rules>
